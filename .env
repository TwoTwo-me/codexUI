COMPOSE_PROJECT_NAME=codexui-hub
CODEXUI_IMAGE=codexui-hub:local
CODEXUI_CONTAINER_NAME=codexui-hub
CODEXUI_EXPOSE_HOST=0.0.0.0
CODEXUI_HOST_PORT=4300
CODEXUI_PORT=4300
CODEXUI_BIND_HOST=0.0.0.0
CODEXUI_ADMIN_USERNAME=admin
