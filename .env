CODEXUI_IMAGE=codexui-hub:local
CODEXUI_CONTAINER_NAME=codexui-hub
CODEXUI_RESTART_POLICY=unless-stopped
CODEXUI_BIND_HOST=0.0.0.0
CODEXUI_PORT=4300
CODEXUI_PASSWORD_MODE=required
CODEXUI_PASSWORD=change-me-now
CODEXUI_DATA_DIR=./docker/data
CODEXUI_CODEX_AUTH_FILE=./docker/secrets/codex-auth.json
CODEXUI_CODEX_CLI_VERSION=0.110.0
